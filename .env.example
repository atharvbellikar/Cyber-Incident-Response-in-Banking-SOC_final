# ── SOC backend (FastAPI) ────────────────────────────────────────────────────
# Copy to .env and adjust for your environment.

# Path to the SQLite database file (use a persistent volume in production).
SOC_DB_PATH=./soc_incidents.db

# Comma-separated allowlist of frontend origins permitted by CORS.
SOC_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional API key. When set, all /api and /run-pipeline endpoints require the
# `X-API-Key` header. Leave empty for open local development.
SOC_API_KEY=

# Upload / input limits (DoS protection).
SOC_MAX_UPLOAD_BYTES=10485760     # 10 MB
SOC_MAX_EVENTS=5000

# Ollama (Layer 4 AI). The pipeline falls back to rule-based analysis if absent.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=30

# Logging / environment.
SOC_LOG_LEVEL=INFO
SOC_ENV=development

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Base URL the Next.js server-side route handlers use to reach the backend.
BACKEND_URL=http://127.0.0.1:8000
# Forwarded as X-API-Key to the backend when backend auth is enabled.
BACKEND_API_KEY=
